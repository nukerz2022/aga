# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here_for_testing

# Bot Owner
OWNER_ID=your_discord_user_id

# Support Server
SUPPORT_SERVER=https://discord.gg/yourinvite
SUPPORT_SERVER_ID=your_support_server_id

# Bot Settings
BOT_NAME=FiveM Player Finder V5
BOT_VERSION=5.0.0
BOT_PREFIX=/

# Database
DB_PATH=./src/database/database.sqlite

# FiveM API
FIVEM_API_BASE=https://servers-frontend.fivem.net/api/servers/single
FIVEM_API_TIMEOUT=10000

# Payment (QRIS)
QRIS_IMAGE_URL=https://your-qris-image-url.com/qris.png
PAYMENT_ADMIN_ID=your_admin_discord_id

# Subscription Prices (in IDR)
PRICE_1_MONTH=15000
PRICE_3_MONTHS=35000
PRICE_LIFETIME=99000

# Cache TTL (milliseconds)
CACHE_TTL=30000
SERVER_CACHE_TTL=60000

# Loop Interval Limits (seconds)
LOOP_MIN_INTERVAL=30
LOOP_MAX_INTERVAL=3600
